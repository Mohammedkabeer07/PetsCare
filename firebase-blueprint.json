{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Animal": {
      "title": "Animal",
      "description": "Animal available for adoption",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "species": { "type": "string" },
        "breed": { "type": "string" },
        "age": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "adopted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "species", "status"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["veterinary", "grooming"] },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceType", "date", "time", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/animals/{animalId}": {
      "schema": "Animal",
      "description": "Animal listings"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    }
  }
}
